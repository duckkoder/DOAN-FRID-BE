# Environment Variables Example
# Copy this file to .env and update with your values

# Project
PROJECT_NAME=AI Attendance System
VERSION=1.0.0
API_V1_STR=/api/v1

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/attendance_db

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# Email (Optional - for future use)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-password
# EMAILS_FROM_EMAIL=noreply@attendance.com

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=PATH_TO_YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=PATH_TO_YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=PATH_TO_YOUR_AWS_REGION
AWS_S3_BUCKET_NAME=PATH_TO_YOUR_S3_BUCKET_NAME

S3_PRIVATE_FOLDER=private
S3_PUBLIC_FOLDER=public
#File
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,gif,webp
ALLOWED_DOCUMENT_EXTENSIONS=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif,webp

# AI Service Integration
AI_SERVICE_URL=http://localhost:8096
# ⚠️ IMPORTANT: BACKEND_BASE_URL phải match với port backend đang chạy
# Backend thường chạy trên port 8000, AI-Service sẽ gọi callback đến URL này
BACKEND_BASE_URL=http://localhost:8000
AI_SERVICE_SECRET=shared-secret-key-for-hmac-verification-change-this
AI_WEBSOCKET_TOKEN_EXPIRE_MINUTES=30
