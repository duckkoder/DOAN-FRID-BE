# ============================================
# .dockerignore - Loại trừ file không cần thiết
# Giảm kích thước build context và tăng tốc build
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# Testing
.pytest_cache/
.coverage
htmlcov/
*.cover

# Database
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# Environment variables (sẽ inject khi deploy)
.env
.env.local
.env.*.local

# Documentation
README.md
docs/
*.md

# Docker files (không cần trong container)
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml

# OS
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Large model files (nếu có, nên tải từ cloud)
models/*.pth
models/*.pt
models/*.onnx
weights/
checkpoints/

